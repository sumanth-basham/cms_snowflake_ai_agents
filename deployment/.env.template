SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=CMS_STARS_ADMIN
SNOWFLAKE_WAREHOUSE=CMS_STARS_WH
SNOWFLAKE_DATABASE=CMS_STARS_DB
SNOWFLAKE_SCHEMA=SCHEMA_GOLD

# ---------------------------------------------------------------------------
# Authentication — choose ONE of the three methods below.
# ---------------------------------------------------------------------------

# METHOD 1 (recommended for CI/CD): Programmatic Access Token (PAT)
#   How to generate: Snowflake UI → User Menu → My Profile →
#                    Security → Programmatic Access Tokens → + New Token
#   Then paste the token value here.  Leave blank to use another method.
SNOWFLAKE_PAT=

# METHOD 2: Key-pair (JWT) authentication
#   Set SNOWFLAKE_AUTHENTICATOR=snowflake_jwt and point to your PEM file.
#   Leave SNOWFLAKE_PAT blank when using this method.
SNOWFLAKE_AUTHENTICATOR=
# Path to private key file (PEM) — used when SNOWFLAKE_AUTHENTICATOR=snowflake_jwt
SNOWFLAKE_PRIVATE_KEY_PATH=

# METHOD 3: Password authentication (least preferred for CI/CD)
#   Leave SNOWFLAKE_PAT and SNOWFLAKE_AUTHENTICATOR blank.
SNOWFLAKE_PASSWORD=

CORTEX_LLM_MODEL=mistral-large2
CORTEX_EMBED_MODEL=snowflake-arctic-embed-l-v2.0
MEASUREMENT_YEAR=2024
